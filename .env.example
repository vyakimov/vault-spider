# Secrets and provider settings. Copy to .env (gitignored) and fill in.
# Everything that is not a secret belongs in config.yaml instead.

# Required. https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Required. Any embedding model your OpenRouter account can reach.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Required. Used for synthesis and the enrichment planner.
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini

# Optional. Set to enable reranking in `--mode thorough`; without it, thorough
# behaves like fast plus recency.
# OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5

# Optional. Defaults are fine for most setups.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=Vault RAG

# vault-spider configuration.
#
# Everything installation-specific lives here: where your vault is, which folders to
# skip, which tags mean "never index", how timestamps are written. Nothing personal is
# baked into the source.
#
# Copy to config.yaml (gitignored) and edit. The file is OPTIONAL — without it the
# read path falls back to the active vault in Obsidian's registry.
#
# Secrets do NOT belong here. API keys go in .env (see .env.example).
#
# VAULT_SPIDER_CONFIG can point at this file somewhere else.

vault:
  # Default corpus root after an explicit --root. `~` is expanded and relative paths
  # are resolved from this config file's directory. Leave unset (null) to use the
  # active vault from Obsidian's registry.
  root: ~/Documents/MyVault

  # Directory names never indexed, at any depth. Add your Templater folder here —
  # Obsidian setups often name it something like "999 Templates" or "_templates".
  # Hidden directories (.git, plugin caches, ...) are always skipped.
  skip_dirs:
    - .trash
    - .obsidian
    - Templates

  # A note carrying any of these tags — in its frontmatter `tags:` or as a #tag in
  # the body — is never indexed. This is the escape hatch for private notes: they
  # stay in Obsidian but never reach the vector store or an LLM.
  ignore_tags:
    - ignore
    - secret

  # Where `synthesize --save` writes distilled notes, relative to the vault root.
  distilled_dir: Distilled

  # The known `source_type` vocabulary for `enrich`. Caller-supplied slugs outside
  # this list are still accepted (with a warning in the plan); LLM-proposed values
  # outside it are dropped. Values are lowercase slugs (letters/digits/dashes).
  source_types:
    - transcript
    - web
    - pdf
    - manual
    - llm

index:
  # ChromaDB persistence directory, relative to this config file (or an absolute path).
  chroma_path: chroma_db

timestamps:
  # How `--fix`/`--fix-timestamps`/distilled notes write `created`/`updated`:
  #   offset_local  — 2026-07-13T14:30:00+02:00 (local wall-clock + offset)
  #   utc_z         — 2026-07-13T12:30:00Z
  #   obsidian_local — 2026-07-13T14:30:00 (Obsidian-native Date & time value;
  #                    no offset, rendered using the OS locale in Obsidian)
  # A timestamp without an offset is interpreted as local wall-clock time.
  policy: offset_local

obsidian:
  # Connection facts for the note-mutation commands (create-note, merge-frontmatter,
  # add-links, insert-related, move-note, rename-note, open-note). These commands
  # go through the official Obsidian CLI, so the Obsidian app must be running.
  #
  # Path to the official `obsidian` CLI binary. Relative paths resolve from this
  # config file's directory. Leave unset to auto-discover (/usr/local/bin/obsidian,
  # then the app bundle).
  binary: null

  # Obsidian vault NAME (not a path — the vault as named in Obsidian's vault
  # switcher). When set alongside vault.root, both must identify the same registered
  # vault or commands fail with config_mismatch. When unset, vault.root is mapped to
  # its registered name; with neither configured, commands target the active vault.
  # Per-command --vault deliberately bypasses this consistency guard.
  vault: null

  # Whether the mutation commands should patch `updated` themselves after a
  # content edit. Leave false when a plugin (e.g. update-time-on-edit) already
  # maintains `updated` — stamping it here too would double-write it.
  manage_updated: false
